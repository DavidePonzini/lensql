#: server/api/auth.py:32
msgid "Cannot login. Please check your username and password."
msgstr "Accesso non riuscito. Controlla nome utente e password."

#: server/api/auth.py:72
msgid "Username already exists. Please choose a different username."
msgstr "Il nome utente esiste già. Scegline un altro."

#: server/api/auth.py:80
msgid "Registration failed. Please try again."
msgstr "Registrazione non riuscita. Riprova."

#: server/api/auth.py:95
msgid "Old password is incorrect."
msgstr "La password è incorretta."

#: server/api/auth.py:98
msgid "Failed to reset password. Please try again."
msgstr "Impossibile reimpostare la password. Riprova."

#: server/api/auth.py:100
msgid "Password reset successfully."
msgstr "Password reimpostata con successo."

#: server/api/datasets.py:65
msgid "You are not authorized to modify this dataset."
msgstr "Non sei autorizzato a modificare questo dataset."

#: server/api/datasets.py:92 server/api/datasets.py:207
msgid "You do not have access to this dataset."
msgstr "Non hai accesso a questo dataset."

#: server/api/datasets.py:116
msgid "Dataset does not exist."
msgstr "Il dataset non esiste."

#: server/api/datasets.py:143
msgid "This is a special dataset and cannot be left."
msgstr "Questo è un dataset speciale e non può essere abbandonato"

#: server/api/datasets.py:148
msgid ""
"You cannot leave this dataset, as you are an owner and it has data "
"associated with it."
msgstr ""
"Non puoi abbandonare questo dataset perché sei un proprietario e contiene"
" dei dati associati."

#: server/api/datasets.py:174 server/api/datasets.py:192
msgid "You are not an owner of this dataset."
msgstr "Non sei un proprietario di questo dataset."

#: server/api/datasets.py:177
msgid "You cannot set yourself as an owner of this dataset."
msgstr "Non puoi assegnarti come proprietario di questo dataset."

#: server/api/exercises.py:26
msgid "Dataset ID is required."
msgstr "ID dataset richiesto"

#: server/api/exercises.py:31 server/api/exercises.py:131
#: server/api/exercises.py:219
msgid "You are not a participant of this dataset."
msgstr "Non sei un partecipante di questo dataset."

#: server/api/exercises.py:58
msgid "You are not authorized to add exercises to this dataset."
msgstr "Non sei autorizzato ad aggiungere esercizi a questo dataset."

#: server/api/exercises.py:84 server/api/exercises.py:175
msgid "You are not authorized to edit this exercise."
msgstr "Non sei autorizzato a modificare questo esercizio."

#: server/api/exercises.py:104
msgid "You are not authorized to delete this exercise."
msgstr "Non sei autorizzato a cancellare questo esercizio."

#: server/api/exercises.py:109
msgid "Cannot delete exercise. There are queries associated with it."
msgstr "Impossibile eliminare l'esercizio. Ci sono query associate."

#: server/api/exercises.py:126
msgid "Exercise ID is required."
msgstr "ID esercizio richiesto."

#: server/api/exercises.py:149
msgid "You are not authorized to set learning objectives for this exercise."
msgstr ""
"Non sei autorizzato a impostare gli obiettivi didattici per questo "
"esercizio."

#: server/api/messages.py:64 server/api/messages.py:99
#: server/api/messages.py:133 server/api/messages.py:167
#: server/api/messages.py:201 server/api/messages.py:233
#: server/api/messages.py:265
msgid ""
"AI features are disabled for your account. Please contact support if you "
"believe this is an error."
msgstr ""
"Le funzionalità di intelligenza artificiale sono disattivate per il tuo "
"account. Contatta l’assistenza se ritieni che si tratti di un errore."

#: server/api/messages.py:277
msgid "Congratulations, I couldn't find any errors in your query!"
msgstr "Congratulazioni, non ho trovato alcun errore nella tua query!"

#: server/api/users.py:62 server/api/users.py:106 server/api/users.py:143
msgid "User is not a participant in the specified dataset."
msgstr "L'utente non è un partecipante del dataset specificato."

#: server/db/users/database.py:250 server/db/users/database.py:259
msgid "No tables found in the current search path."
msgstr ""

#: server/db/users/database.py:268
msgid "No constraints found in the current search path."
msgstr ""

#: server/db/users/database.py:422
msgid "No solution found for this exercise."
msgstr "Nessuna soluzione trovata per questo esercizio."

#: server/db/users/database.py:428
msgid "Your query is not supported. Please ensure it is a valid SQL SELECT query."
msgstr ""
"La tua query non è supportata. Assicurati che sia una query SQL SELECT "
"valida."

#: server/db/users/database.py:437
msgid ""
"Error executing teacher-provided solution. Have you initialized the "
"dataset?"
msgstr ""
"Errore nell'esecuzione della soluzione fornita dall'insegnante. Hai "
"inizializzato il dataset?"

#: server/db/users/database.py:445
msgid ""
"Your query has different columns from the solution. Cannot compare "
"results."
msgstr ""
"La tua query ha colonne diverse rispetto alla soluzione. Impossibile "
"confrontare i risultati."

#: server/db/users/database.py:446 server/db/users/database.py:458
msgid "Expected:"
msgstr "Atteso:"

#: server/db/users/database.py:447 server/db/users/database.py:459
msgid "Your query:"
msgstr "La tua query:"

#: server/db/users/database.py:457
msgid ""
"Your query has different data types from the solution. Cannot compare "
"results."
msgstr ""
"La tua query ha tipi di dati diversi rispetto alla soluzione. Impossibile"
" confrontare i risultati."

#: server/db/users/database.py:468
msgid "Your query returns the same values as the solution."
msgstr ""

#: server/gamification/__init__.py:8
msgid ""
"You don't have enough coins to use this feature. Check the Profile page "
"to learn how to earn more."
msgstr ""
"Non hai abbastanza monete per usare questa funzione. Consulta la pagina "
"del profilo per scoprire come guadagnarne di più."

